# Helpdesk Example Environment Variables
# Copy this file to .env.local and fill in your values

# Gemini API Key (required for LLM and embeddings)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL Database URL (required for event storage)
# Format: postgresql://user:password@host:port/database
HELPDESK_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/orchid

# Optional: Override Qdrant URL (default: http://qdrant:6333)
# QDRANT_URL=http://localhost:6333

# Optional: Override Ollama API base (if using Ollama models)
# OLLAMA_API_BASE=http://host.docker.internal:11434
